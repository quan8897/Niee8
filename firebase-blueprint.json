{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Fashion product details for niee8",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["name", "price", "category"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback and testimonials",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user": { "type": "string" },
        "text": { "type": "string" },
        "avatar": { "type": "string" }
      },
      "required": ["user", "text"]
    },
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "client"] }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/products": {
      "schema": "Product",
      "description": "Collection of fashion products"
    },
    "/feedbacks": {
      "schema": "Feedback",
      "description": "Collection of user feedbacks"
    },
    "/users": {
      "schema": "User",
      "description": "Collection of user profiles"
    }
  }
}
